#!/usr/bin/env bash
set -eo pipefail

releases_url="https://mirror.openshift.com/pub/openshift-v4/clients/ocp/"

# Fetch the release page, extract the version directories, strip HTML, and sort.
# - grep: specifically matches pure version numbers (4.14.8) and channels (stable-4.20)
# - sed 1: removes the start of the href tag
# - sed 2: removes the trailing slash and closing tag
# - sort -V: ensures 4.2 comes before 4.10 (Version sort)

curl --silent --location "$releases_url" \
  | grep -o "<a href=\"\(\(latest\|candidate\|stable\|fast\)-\)\?\([0-9\.\-]\)\+/\">" \
  | sed 's/<a href="//g' \
  | sed 's/\/">//g' \
  | sort -V
