#!/usr/bin/env bash

# Added 'x' to print trace
set -ex

install_oi() {
  local download_path=$1
  local install_path=$2

  # DEBUG: Check if the file is actually here before copying
  echo "--- CHECKING IF BINARY EXISTS BEFORE COPY ---"
  ls -la "${download_path}"

  mkdir -p "${install_path}/bin"

  # Copy the extracted binary
  cp "${download_path}/openshift-install" "${install_path}/bin/openshift-install"

  chmod +x "${install_path}/bin/openshift-install"
}

[ -n "$ASDF_DOWNLOAD_PATH" ] || exit 1
[ -n "$ASDF_INSTALL_PATH" ] || exit 1

install_oi "$ASDF_DOWNLOAD_PATH" "$ASDF_INSTALL_PATH"
